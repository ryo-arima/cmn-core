Application:
  Common: {}
  Server:
    port: 8000
    admin:
      emails:
        - "admin@cmn.local"
    jwt_secret: "CHANGE_THIS_JWT_SECRET_IN_PRODUCTION"
    log_level: "debug"
    # Redis-related configurations
    redis:
      # Enable JWT token caching in Redis for better performance
      jwt_cache: true
      # JWT cache TTL in seconds (1800 = 30 minutes, 0 = use token expiry)
      cache_ttl: 1800
    # Identity provider for user/group management.
    # provider: "keycloak" or "casdoor"
    idp:
      provider: "casdoor"
      casdoor:
        base_url: "http://localhost:8000"
        client_id: "CHANGE_THIS_CLIENT_ID"
        client_secret: "CHANGE_THIS_CLIENT_SECRET"
        organization: "built-in"
      # keycloak:
      #   base_url: "http://localhost:8080"
      #   realm: "master"
      #   admin_client_id: "admin-cli"
      #   admin_client_secret: "CHANGE_THIS_SECRET"
    # OIDC settings for JWT validation.
    # issuer_url must match the `iss` claim in tokens issued by the IdP.
    # provider_url is the OIDC discovery URL; set it to the internal service URL
    # when running in Docker if the public issuer URL is not reachable from within
    # the container network (e.g. provider_url: "http://casdoor:8000").
    # If provider_url is omitted, issuer_url is used.
    auth:
      oidc:
        issuer_url: "http://localhost:9000"
        provider_url: "http://localhost:9000"
        client_id: "CHANGE_THIS_CLIENT_ID"

PostgreSQL:
  host: "localhost"
  user: "user"
  pass: "password"
  port: "5432"
  db: "cmn_core"
  sslmode: "disable"

Redis:
  host: "localhost"
  port: 6379
  user: "default"
  pass: "redis_password"
  db: 0
