Application:
  Common: {}
  Server:
    port: 8000
    admin:
      emails:
        - "admin@example.com"
    jwt_secret: "CHANGE_THIS_JWT_SECRET_IN_PRODUCTION"
    log_level: "debug"
    # Redis-related configurations
    redis:
      # Enable JWT token caching in Redis for better performance
      jwt_cache: true
      # JWT cache TTL in seconds (1800 = 30 minutes, 0 = use token expiry)
      cache_ttl: 1800
    jwt:
      key: "CHANGE_THIS_JWT_KEY"
    mail:
      host: "smtp.example.com"
      port: 587
      user: "your-smtp-username"
    tmp:
      letters: ""
      length: 6
  Client:
    HomePath: "etc/.cmn"
    ServerEndpoint: "http://localhost:8000"
    # auth configures the SSO provider used by the CLI clients (cmn-admin, cmn-app).
    # The provider value must match what is configured on the server side.
    auth:
      # provider: "oidc" or "saml"
      provider: "oidc"
      # no_browser: set to true in headless/CI environments to skip auto browser open
      no_browser: false
    HomeDir: "etc/.cmn"
    TemplatesDir: "pkg/client/repository/templates/"

PostgreSQL:
  host: "localhost"
  user: "user"
  pass: "password"
  port: "5432"
  db: "cmn_core"
  sslmode: "disable"

Redis:
  host: "localhost"
  port: 6379
  user: "default"
  pass: "redis_password"
  db: "redis_database_name"